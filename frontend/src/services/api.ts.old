// ==================== SERVICE MÉDIAS ====================

export const mediaService = {
  upload: (file: File, entityType: string, entityId: string) => {
    const formData = new FormData();
    formData.append('file', file);
    formData.append('entityType', entityType);
    formData.append('entityId', entityId);
    return api.post<ApiResponse<any>>('/media/upload', formData, { 
      headers: { 'Content-Type': 'multipart/form-data' },
      timeout: 60000, // 60 secondes pour l'upload
    });
  },
  
  getAll: (params?: { entityType?: string; entityId?: string }) => 
    api.get<PaginatedResponse<any>>('/media', { params }),
  
  getById: (id: string) => 
    api.get<ApiResponse<any>>(`/media/${id}`),
  
  delete: (id: string) => 
    api.delete<ApiResponse<{ message: string }>>(`/media/${id}`),
  
  getStats: () => 
    api.get<ApiResponse<any>>('/media/stats'),
};

