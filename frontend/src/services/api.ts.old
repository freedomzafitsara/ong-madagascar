// src/services/api.ts
import axios, { AxiosInstance, AxiosError, InternalAxiosRequestConfig } from 'axios';

// ==================== CONFIGURATION ====================

const API_URL = process.env.NEXT_PUBLIC_API_URL || 'http://localhost:4001/api';

// Configuration de base
export const api: AxiosInstance = axios.create({
  baseURL: API_URL,
  headers: { 
    'Content-Type': 'application/json',
    'Accept': 'application/json',
  },
  timeout: 30000, // 30 secondes
});

// ==================== INTERCEPTEURS ====================

// Intercepteur de requęte - Ajout du token
api.interceptors.request.use(
  (config: InternalAxiosRequestConfig): InternalAxiosRequestConfig => {
    // Récupérer le token depuis localStorage
    const token = typeof window !== 'undefined' ? localStorage.getItem('token') : null;
    
    if (token && config.headers) {
      config.headers.Authorization = `Bearer ${token}`;
    }
    
    return config;
  },
  (error: AxiosError): Promise<AxiosError> => {
    console.error('Erreur de requęte:', error);
    return Promise.reject(error);
  }
);

// Intercepteur de réponse - Gestion des erreurs
api.interceptors.response.use(
  (response) => response,
  async (error: AxiosError) => {
    const originalRequest = error.config as InternalAxiosRequestConfig & { _retry?: boolean };
    
    // Gestion des erreurs 401 (Non autorisé)
    if (error.response?.status === 401 && !originalRequest._retry) {
      originalRequest._retry = true;
      
      // Token refresh (si implémenté)
      // const refreshToken = localStorage.getItem('refreshToken');
      // if (refreshToken) {
      //   try {
      //     const response = await axios.post(`${API_URL}/auth/refresh`, { refreshToken });
      //     const { token } = response.data;
      //     localStorage.setItem('token', token);
      //     originalRequest.headers.Authorization = `Bearer ${token}`;
      //     return api(originalRequest);
      //   } catch (refreshError) {
      //     // Rediriger vers login
      //     if (typeof window !== 'undefined') {
      //       localStorage.removeItem('token');
      //       localStorage.removeItem('user');
      //       window.location.href = '/login';
      //     }
      //   }
      // } else {
        // Rediriger vers login
        if (typeof window !== 'undefined') {
          localStorage.removeItem('token');
          localStorage.removeItem('user');
          localStorage.removeItem('admin_token');
          window.location.href = '/login';
        }
      // }
    }
    
    // Message d'erreur personnalisé
    const errorMessage = (error.response?.data as any)?.message || error.message || 'Une erreur est survenue';
    console.error('API Error:', errorMessage);
    
    return Promise.reject(error);
  }
);

// ==================== TYPES ====================

export interface ApiResponse<T = any> {
  success: boolean;
  data: T;
  message?: string;
  errors?: string[];
}

export interface PaginatedResponse<T> {
  data: T[];
  total: number;
  page: number;
  limit: number;
  totalPages: number;
}

// ==================== SERVICE AUTHENTIFICATION ====================

export const authService = {
  /**
   * Connexion utilisateur
   */
  login: (email: string, password: string) => 
    api.post<ApiResponse<{ token: string; user: any }>>('/auth/login', { email, password }),
  
  /**
   * Inscription utilisateur
   */
  register: (data: any) => 
    api.post<ApiResponse<{ token: string; user: any }>>('/auth/register', data),
  
  /**
   * Récupérer le profil utilisateur
   */
  getProfile: () => 
    api.get<ApiResponse<any>>('/auth/profile'),
  
  /**
   * Mettre ŕ jour le profil
   */
  updateProfile: (data: any) => 
    api.put<ApiResponse<any>>('/auth/profile', data),
  
  /**
   * Changer le mot de passe
   */
  changePassword: (oldPassword: string, newPassword: string) => 
    api.post<ApiResponse<{ message: string }>>('/auth/change-password', { oldPassword, newPassword }),
  
  /**
   * Demander réinitialisation du mot de passe
   */
  forgotPassword: (email: string) => 
    api.post<ApiResponse<{ message: string }>>('/auth/forgot-password', { email }),
  
  /**
   * Réinitialiser le mot de passe
   */
  resetPassword: (token: string, password: string) => 
    api.post<ApiResponse<{ message: string }>>('/auth/reset-password', { token, password }),
  
  /**
   * Déconnexion
   */
  logout: () => {
    if (typeof window !== 'undefined') {
      localStorage.removeItem('token');
      localStorage.removeItem('user');
      localStorage.removeItem('admin_token');
      sessionStorage.removeItem('token');
      sessionStorage.removeItem('admin_token');
    }
  },
  
  /**
   * Rafraîchir le token
   */
  refreshToken: () => 
    api.post<ApiResponse<{ token: string }>>('/auth/refresh'),
};

// ==================== SERVICE PROJETS ====================

export const projectService = {
  getAll: (params?: any) => 
    api.get<PaginatedResponse<any>>('/projects', { params }),
  
  getById: (id: string) => 
    api.get<ApiResponse<any>>(`/projects/${id}`),
  
  create: (data: any) => 
    api.post<ApiResponse<any>>('/projects', data),
  
  update: (id: string, data: any) => 
    api.put<ApiResponse<any>>(`/projects/${id}`, data),
  
  delete: (id: string) => 
    api.delete<ApiResponse<{ message: string }>>(`/projects/${id}`),
  
  getStats: () => 
    api.get<ApiResponse<any>>('/projects/stats'),
  
  getBeneficiaries: (id: string) => 
    api.get<PaginatedResponse<any>>(`/projects/${id}/beneficiaries`),
  
  addBeneficiary: (id: string, beneficiaryId: string) => 
    api.post<ApiResponse<any>>(`/projects/${id}/beneficiaries`, { beneficiaryId }),
  
  removeBeneficiary: (id: string, beneficiaryId: string) => 
    api.delete<ApiResponse<{ message: string }>>(`/projects/${id}/beneficiaries/${beneficiaryId}`),
  
  getImages: (id: string) => 
    api.get<ApiResponse<any[]>>(`/projects/${id}/images`),
  
  uploadImage: (id: string, file: File) => {
    const formData = new FormData();
    formData.append('image', file);
    return api.post<ApiResponse<any>>(`/projects/${id}/images`, formData, {
      headers: { 'Content-Type': 'multipart/form-data' },
    });
  },
  
  setMainImage: (id: string, imageId: string) => 
    api.patch<ApiResponse<any>>(`/projects/${id}/images/${imageId}/main`),
  
  deleteImage: (id: string, imageId: string) => 
    api.delete<ApiResponse<{ message: string }>>(`/projects/${id}/images/${imageId}`),
};

